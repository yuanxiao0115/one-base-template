# Copy to `.env.development.local` for local development.

# Build-time config (Vite dev/proxy only).
# Runtime business config has moved to `apps/admin/public/platform-config.json`.

# sczfw gateway base url (used by Vite proxy for /api and /cmict).
# Example from legacy project.
VITE_API_BASE_URL=https://gateway-sczfw-30746.p.onecode.cmict.cloud

# Optional: enable local readonly snapshot fallback for platform-config bootstrap failures.
# VITE_ENABLE_PLATFORM_CONFIG_SNAPSHOT_FALLBACK=true
