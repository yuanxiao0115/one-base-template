{
  "version": "1",
  "updatedAt": "2026-03-24",
  "methodVerbs": [
    "get",
    "list",
    "find",
    "load",
    "login",
    "create",
    "add",
    "update",
    "remove",
    "clear",
    "save",
    "reset",
    "parse",
    "build",
    "map",
    "to",
    "set",
    "sync",
    "open",
    "close",
    "start",
    "stop",
    "fetch",
    "warn"
  ],
  "storeActionVerbs": ["set", "update", "reset", "clear", "load"],
  "apiClientVerbs": ["get", "list", "create", "add", "update", "remove", "delete"],
  "eventHandlerPrefix": "on",
  "composablePrefix": "use",
  "predicateVerbs": ["is", "has", "can", "should"],
  "discouragedVerbs": [
    "assemble",
    "orchestrate",
    "resolve",
    "process",
    "execute",
    "perform",
    "manage"
  ],
  "rules": {
    "methodPattern": "verb + noun",
    "preferShortNames": true,
    "allowHandleOnlyForEvents": true
  },
  "allowedNameExemptions": [],
  "checkTargets": {
    "adminRouter": "apps/admin/src/router",
    "adminAuthServices": "apps/admin/src/services/auth",
    "adminModuleApi": "apps/admin/src/modules/**/api",
    "adminModuleServices": "apps/admin/src/modules/**/services",
    "adminModuleEntry": "apps/admin/src/modules/**/module.ts",
    "portalAuthServices": "apps/portal/src/services/auth",
    "portalModuleApi": "apps/portal/src/modules/**/api",
    "portalModuleServices": "apps/portal/src/modules/**/services",
    "portalModuleEntry": "apps/portal/src/modules/**/module.ts",
    "templateModuleRoutes": "apps/template/src/modules/**/routes.ts"
  }
}
