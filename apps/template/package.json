{
  "name": "template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "node ../../scripts/run-vp-build.mjs",
    "preview": "vp preview",
    "typecheck": "vue-tsc --noEmit",
