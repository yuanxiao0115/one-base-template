    "@one-base-template/core": "workspace:*",
    "@one-base-template/tag": "workspace:*",
    "@one-base-template/ui": "workspace:*",
    "element-plus": "^2.13.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.28",
    "vue-router": "^5.0.2"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.4",
    "ultracite": "^7.2.4",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  }
