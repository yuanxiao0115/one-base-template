# Copy to `.env.development.local` for local development.

# Build-time config (Vite dev/proxy only).
# Business platform config is maintained in `apps/zfw-system-sfss/src/config/platform-config.ts`.

# basic gateway base url (used by Vite proxy for /api and /cmict).
# Example from legacy project.
VITE_API_BASE_URL=https://gateway-basic-30746.p.onecode.cmict.cloud

# metrics gateway base url (used by Vite proxy for /zb/* -> /*).
# If omitted, dev proxy falls back to VITE_API_BASE_URL.
VITE_ZB_BASE_URL=https://gateway-metricsplatform-dev-30746.p.onecode.cmict.cloud

# sfss LM service base url (used by Vite proxy for /zfw/*).
# If omitted, dev proxy falls back to VITE_API_BASE_URL.
VITE_API_LM_URL=http://11.11.54.110:9999

# app base prefix (also used as router base).
# Examples:
# - root deploy: /
# - sub-path deploy: /admin-lite/
VITE_APP_BASE=/
