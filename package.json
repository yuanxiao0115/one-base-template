{
  "name": "one-base-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20.11.1",
    "pnpm": ">=9.1.4"
  },
  "scripts": {
    "dev": "vp run --filter admin dev",
    "dev:template": "vp run --filter template dev",
    "dev:portal": "vp run --filter portal dev",
    "dev:all": "vp run -r dev",
    "new:module": "node ./scripts/new-module.mjs",
    "build": "vp run -r build",
    "typecheck": "vp run -r typecheck",
    "lint": "vp run -r lint",
    "lint:arch": "vp run --filter admin lint:arch",
    "check:admin:bundle": "node ./scripts/check-admin-build-size.mjs",
    "test": "vp run -r test",
    "test:run": "vp run -r test:run",
    "biome:format": "pnpm exec biome format --config-path ./biome.jsonc --write .",
    "biome:lint": "pnpm exec biome lint --config-path ./biome.jsonc .",
    "biome:check": "pnpm exec biome check --config-path ./biome.jsonc --write .",
    "biome:unsafe": "pnpm exec biome check --config-path ./biome.jsonc --write --unsafe .",
    "biome:ci": "pnpm exec biome ci --config-path ./biome.jsonc .",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "release:packages": "changeset publish",
    "check:naming": "node ./scripts/check-naming.mjs",
    "verify": "vp run --filter @one-base-template/portal-engine verify:materials && pnpm lint:arch && pnpm test:run && pnpm typecheck && pnpm lint && pnpm build && pnpm check:admin:bundle",
    "doctor": "node ./scripts/doctor.mjs",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^10.0.1",
    "eslint-plugin-vue": "^10.8.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.56.1",
    "ultracite": "^7.2.4",
    "vue-tsc": "^2.0.0",
    "vite-plus": "catalog:"
  }
}
