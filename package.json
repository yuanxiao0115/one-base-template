{
  "name": "one-base-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.32.1"
  },
  "scripts": {
    "dev": "vp run --filter admin dev",
    "dev:admin-lite": "vp run --filter admin-lite dev",
    "dev:portal": "vp run --filter portal dev",
    "dev:all": "vp run -r dev",
    "new:app": "node ./scripts/new-app.mjs",
    "mirror:pure-table": "node ./scripts/sync-pure-admin-table-mirror.mjs",
    "build": "vp run -r build",
    "typecheck": "vp run -r typecheck",
    "lint": "vp run -r lint",
    "lint:arch": "node ./scripts/run-app-lint-arch.mjs && pnpm check:basic-signature",
    "check:admin:route-policy": "pnpm -C apps/admin check:route-policy",
    "check:admin:bundle": "node ./scripts/check-admin-build-size.mjs",
    "check:admin-lite:bundle": "node ./scripts/check-admin-lite-build-size.mjs",
    "test:e2e:minimal-auth": "pnpm -C packages/core test:run -- src/router/auth-minimal-e2e.unit.test.ts && pnpm -C apps/admin test:e2e:minimal-auth",
    "check:basic-signature": "node ./scripts/check-basic-signature-boundary.mjs",
    "test": "vp run -r test",
    "test:run": "vp run -r test:run",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "release:packages": "changeset publish",
    "check:naming:config": "node ./scripts/check-naming-whitelist-schema.mjs",
    "check:naming": "pnpm check:naming:config && node ./scripts/check-naming.mjs",
    "verify": "vp run --filter @one-base-template/portal-engine verify:materials && pnpm check:naming && pnpm check:admin:route-policy && pnpm lint:arch && pnpm test:run && pnpm typecheck && pnpm lint && pnpm build && pnpm check:admin:bundle && pnpm check:admin-lite:bundle",
    "doctor": "node ./scripts/doctor.mjs",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^10.0.1",
    "eslint-plugin-better-tailwindcss": "^4.3.2",
    "eslint-plugin-vue": "^10.8.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.56.1",
    "vite-plus": "catalog:",
    "vue-tsc": "^2.0.0"
  }
}
