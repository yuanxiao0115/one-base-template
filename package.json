{
  "name": "one-base-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20.11.1",
    "pnpm": ">=9.1.4"
  },
  "scripts": {
    "dev": "pnpm -C apps/admin dev",
    "dev:turbo": "turbo run dev",
    "new:module": "node ./scripts/new-module.mjs",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "release:packages": "changeset publish",
    "test:admin:arch": "pnpm -C apps/admin exec vitest run src/router/__tests__/registry.test.ts src/router/__tests__/skip-menu-auth.test.ts",
    "check:naming": "node ./scripts/check-naming.mjs",
    "verify": "pnpm typecheck && pnpm lint && pnpm test:admin:arch && pnpm check:naming && pnpm build",
    "doctor": "node ./scripts/doctor.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "prettier": "^3.0.0",
    "turbo": "^2.8.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vue-tsc": "^2.0.0"
  }
}
