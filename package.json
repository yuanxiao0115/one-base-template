{
  "name": "one-base-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20.11.1",
    "pnpm": ">=9.1.4"
  },
  "scripts": {
    "dev": "pnpm -C apps/admin dev",
    "dev:template": "pnpm -C apps/template dev",
    "dev:portal": "pnpm -C apps/portal dev",
    "dev:turbo": "turbo run dev",
    "new:module": "node ./scripts/new-module.mjs",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:arch": "pnpm -C apps/admin lint:arch",
    "test": "turbo run test",
    "test:run": "turbo run test:run",
    "biome:format": "pnpm exec biome format --config-path ./biome.jsonc --write .",
    "biome:lint": "pnpm exec biome lint --config-path ./biome.jsonc .",
    "biome:check": "pnpm exec biome check --config-path ./biome.jsonc --write .",
    "biome:unsafe": "pnpm exec biome check --config-path ./biome.jsonc --write --unsafe .",
    "biome:ci": "pnpm exec biome ci --config-path ./biome.jsonc .",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "release:packages": "changeset publish",
    "check:naming": "node ./scripts/check-naming.mjs",
    "verify": "pnpm typecheck && pnpm lint && pnpm check:naming && pnpm build",
    "doctor": "node ./scripts/doctor.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "eslint-plugin-vue": "^10.8.0",
    "prettier": "^3.0.0",
    "turbo": "^2.8.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.56.1",
    "ultracite": "^7.2.4",
    "vue-tsc": "^2.0.0"
  }
}
